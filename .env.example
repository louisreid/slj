# Copy to .env.local and fill in. Do not commit .env.local.
# Get both values from: Supabase Dashboard → Project Settings → API.

# Project URL (e.g. https://xxxx.supabase.co). Safe to expose (public).
NEXT_PUBLIC_SUPABASE_URL=

# Anon/public key. Safe to expose; RLS enforces row-level security.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only vars (e.g. SUPABASE_SERVICE_ROLE_KEY) are not needed for V1; see AGENTS.md if added later.


# Supabase Management API (optional - for scripts that update auth config / email templates)
# Get from: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=