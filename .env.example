# Copy to .env.local and fill in. Do not commit .env.local.
# Get both values from: Supabase Dashboard → Project Settings → API.

# Project URL (e.g. https://xxxx.supabase.co). Safe to expose (public).
NEXT_PUBLIC_SUPABASE_URL=

# Anon/public key. Safe to expose; RLS enforces row-level security.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required for account deletion (Preferences page). Never expose to client.
# Get from: Supabase Dashboard → Project Settings → API → service_role.
# SUPABASE_SERVICE_ROLE_KEY=


# Supabase Management API (optional - for scripts that update auth config / email templates)
# Get from: https://supabase.com/dashboard/account/tokens
# If expired, db push falls back to `supabase login` — or remove this var locally.
SUPABASE_ACCESS_TOKEN=

# Database password (Dashboard → Project Settings → Database). Used by `pnpm db:push` only.
# SUPABASE_DB_PASSWORD=

# Auth redirect base URL (optional). Set to http://localhost:3000 for local dev so magic
# links always redirect to localhost. Omit in production to use the current page origin.
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# E2E only: set by Playwright webServer — never enable in production (bypasses auth for /course and /worksheets/print).
# NEXT_PUBLIC_PLAYWRIGHT_E2E=1